# ==============================================================================
# Kavach-AI (कवच-AI) - Environment Variables Configuration Template
# Copy this file to a file named '.env' in backend/ and frontend/ and configure it.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🧠 AI & LLM Services Configurations
# ------------------------------------------------------------------------------
# Google Gemini API Key for cognitive threat evaluation
GEMINI_API_KEY=your_gemini_api_key_here

# Sarvam AI API Key for speech-to-text, translation, and localized warnings
SARVAM_API_KEY=your_sarvam_api_key_here

# ------------------------------------------------------------------------------
# 📞 Twilio Verification & Notification Configurations
# ------------------------------------------------------------------------------
# Twilio Account SID and Auth Token (from Twilio Console)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Verified Twilio phone number sending the guardian SMS alerts
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Twilio Verify Service SID (starts with VA...) for mobile OTP verification
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid_here

# ------------------------------------------------------------------------------
# ⚙️ Application & Server Settings
# ------------------------------------------------------------------------------
# Backend Server Configurations
PORT=8000
HOST=0.0.0.0

# ------------------------------------------------------------------------------
# 💬 WhatsApp Service Configurations
# ------------------------------------------------------------------------------
# Backend API base URL used by the WhatsApp service
BACKEND_URL=http://localhost:8000

# Meta WhatsApp Cloud API values (mock defaults are safe for local development)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id_here
WHATSAPP_VERIFY_TOKEN=KAVACH_VERIFY_TOKEN_2026
WHATSAPP_APP_SECRET=your_whatsapp_app_secret_here

# Frontend Public Base URL (pointing to the deployed FastAPI server)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
